{
	"name": "paper2card",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && npm run smui-theme",
		"smui-theme": "smui-theme compile static/smui.css -i src/theme",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@ernane/svelte-star-rating": "^1.1.9",
		"@smui/button": "^8.0.3",
		"@smui/circular-progress": "^8.0.3",
		"@smui/dialog": "^8.0.3",
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"fractils": "^3.1.3",
		"smui-theme": "^8.0.3",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"typescript": "^5.9.2",
		"vite": "^7.1.7"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.14",
		"file-saver": "^2.0.5",
		"svelte-collapsible": "^0.3.1",
		"svelte-easy-toast": "^2.0.8",
		"tailwindcss": "^4.1.14",
		"tippy.js": "^6.3.7"
	}
